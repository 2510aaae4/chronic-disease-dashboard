  "sections": [
    {
      "section": 1,
      "title": "Stroke Risk Assessment",
      "title_zh": "中風風險評估",
      "recommendations": [
        {
          "id": "AF1.1",
          "text": "In patients with AF, assessment of stroke risk using the CHA₂DS₂-VA score is recommended to guide antithrombotic therapy decisions.",
          "text_zh": "心房顫動患者建議使用 CHA₂DS₂-VA 評分評估中風風險，以指導抗血栓治療決策。",
          "evidence_level": "A",
          "class": "I",
          "category": "stroke_risk",
          "action": "calculate_cha2ds2va"
        }
      ]
    },
    {
      "section": 2,
      "title": "Bleeding Risk Assessment",
      "title_zh": "出血風險評估",
      "recommendations": [
        {
          "id": "AF2.1",
          "text": "The HAS-BLED score should be considered to identify modifiable bleeding risk factors and patients at high bleeding risk (HAS-BLED ≥3) for early and more frequent follow-up.",
          "text_zh": "應考慮使用 HAS-BLED 評分識別可調整的出血風險因子，以及高出血風險患者 (HAS-BLED ≥3)，進行早期及更頻繁的追蹤。",
          "evidence_level": "B",
          "class": "IIa",
          "category": "bleeding_risk",
          "action": "calculate_hasbled"
        }
      ]
    },
    {
      "section": 3,
      "title": "Anticoagulation Therapy",
      "title_zh": "抗凝血治療",
      "recommendations": [
        {
          "id": "AF3.1",
          "text": "DOACs are recommended in preference to VKAs in DOAC-eligible patients with AF, except for those with mechanical heart valves or moderate-to-severe mitral stenosis.",
          "text_zh": "除機械瓣膜或中重度二尖瓣狹窄患者外，符合條件的心房顫動患者建議優先使用 DOAC 而非 VKA。",
          "evidence_level": "A",
          "class": "I",
          "category": "anticoagulation",
          "action": "recommend_doac"
        }
      ]
    }
  ]
}
